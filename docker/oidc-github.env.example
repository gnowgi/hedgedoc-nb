# =====================================================================
#  GitHub OAuth login for nodebook.co.in  ---  VPS deployment template
# =====================================================================
#
#  HOW TO USE
#  ----------
#  1. On the VPS, append the block below (everything from
#     "HD_AUTH_OIDC_SERVERS=github" onward) to  docker/.env  (which is
#     gitignored on the VPS, so secrets stay off Git).
#
#  2. Replace the two REPLACE_ME values with the GitHub OAuth App
#     credentials (https://github.com/settings/developers).
#
#  3. Recreate the backend container so it picks up the new env:
#         cd docker
#         docker compose up -d --force-recreate --no-deps backend
#     No --build is needed --- branding/auth env is read at runtime.
#
#  4. Visit  https://nodebook.co.in/login  and confirm a
#     "Sign in with GitHub" button appears. Click it to round-trip.
#
#  WHY THESE EXACT KEYS
#  --------------------
#  GitHub is OAuth2, not OIDC, so we (a) set the three endpoint URLs
#  explicitly (this makes HedgeDoc's OIDC client skip the
#  /.well-known/openid-configuration discovery step), and (b) remap
#  the userinfo fields to GitHub's /user response shape:
#      OIDC default    -->  GitHub field
#      sub             -->  id
#      preferred_username -->  login
#      picture         -->  avatar_url
#  HedgeDoc's OIDC service tolerates a missing id_token, so the
#  GitHub round-trip (which returns no id_token) works correctly.
#
#  NOTE on multi-provider:
#  If HD_AUTH_OIDC_SERVERS is already set in the VPS .env (e.g. for
#  Google later), do NOT overwrite it --- change it to a comma list:
#      HD_AUTH_OIDC_SERVERS=google,github
#
# ---------------------------------------------------------------------

# Enable HedgeDoc's OIDC slot and list GitHub as a provider
HD_AUTH_OIDC_SERVERS=github

# --- Credentials from the GitHub OAuth App --------------------------
# Treat the secret like a password; never commit it.
HD_AUTH_OIDC_GITHUB_CLIENT_ID=REPLACE_ME
HD_AUTH_OIDC_GITHUB_CLIENT_SECRET=REPLACE_ME

# --- GitHub endpoints (OAuth2, not OIDC discovery) ------------------
HD_AUTH_OIDC_GITHUB_PROVIDER_NAME=GitHub
HD_AUTH_OIDC_GITHUB_THEME=github
HD_AUTH_OIDC_GITHUB_ISSUER=https://github.com
HD_AUTH_OIDC_GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
HD_AUTH_OIDC_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
HD_AUTH_OIDC_GITHUB_USERINFO_URL=https://api.github.com/user

# read:user is needed for /user; user:email is needed for the email
# (GitHub returns email=null for users whose email is set private; if
# this proves a problem later we can fetch /user/emails too).
HD_AUTH_OIDC_GITHUB_SCOPE=read:user user:email

# --- Map GitHub /user JSON fields to HedgeDoc's expected names ------
HD_AUTH_OIDC_GITHUB_USERNAME_FIELD=login
HD_AUTH_OIDC_GITHUB_USER_ID_FIELD=id
HD_AUTH_OIDC_GITHUB_PROFILE_PICTURE_FIELD=avatar_url
# DISPLAY_NAME_FIELD and EMAIL_FIELD default to 'name' and 'email',
# which already match GitHub --- no overrides needed.

# --- Optional: lock down local registration once GitHub login works -
# Existing local accounts continue to log in; new users must use GitHub.
# Uncomment when you're ready:
# HD_AUTH_LOCAL_ENABLE_REGISTER=false
